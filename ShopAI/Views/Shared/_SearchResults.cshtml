@model SearchResultsViewModel

<div class="mb-6 flex flex-col justify-between gap-3 sm:flex-row sm:items-end">
    <div>
        <p class="text-sm font-black text-brand-600">نتائج فورية</p>
        <h2 class="mt-2 text-2xl font-black tracking-normal text-slate-950">
            @(string.IsNullOrWhiteSpace(Model.Query) ? "تصفح المنتجات" : $"نتائج البحث عن \"{Model.Query}\"")
        </h2>
    </div>
    <p class="rounded-full bg-slate-100 px-4 py-2 text-sm font-black text-slate-600">@Model.TotalResults منتج</p>
</div>

@if (Model.Products.Count == 0)
{
    <div class="rounded-3xl border border-slate-200 bg-white p-12 text-center shadow-soft">
        <div class="mx-auto grid h-16 w-16 place-items-center rounded-3xl bg-brand-50 text-brand-700">
            <i data-lucide="search-x" class="h-7 w-7"></i>
        </div>
        <h2 class="mt-5 text-2xl font-black text-slate-950">لم نجد منتجات مطابقة</h2>
        <p class="mt-3 text-slate-500">جرّب كلمة أخرى أو تصفح الأقسام المتاحة.</p>
        <a class="mt-6 inline-flex rounded-2xl bg-brand-600 px-6 py-3 text-sm font-black text-white" href="/search">تصفح الأقسام</a>
    </div>
}
else
{
    <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var product in Model.Products)
        {
            @await Html.PartialAsync("_ProductCard", product)
        }
    </div>
}

@if (Model.TotalPages > 1)
{
    <div class="mt-10 flex items-center justify-center gap-2">
        @for (var page = 1; page <= Model.TotalPages; page++)
        {
            <button type="button" class="grid h-10 w-10 place-items-center rounded-full text-sm font-black @(page == Model.CurrentPage ? "bg-slate-950 text-white" : "border border-slate-200 bg-white text-slate-700 hover:border-brand-500")" hx-get="/search/results?q=@Uri.EscapeDataString(Model.Query)&category=@Model.CategoryId&page=@(page)" hx-target="#search-results" hx-swap="innerHTML">@(page)</button>
        }
    </div>
}
