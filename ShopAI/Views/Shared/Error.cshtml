@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<section class="mx-auto max-w-3xl px-4 py-16 text-center sm:px-6 lg:px-8">
    <div class="rounded-lg border border-black/10 bg-white p-10 shadow-soft">
        <p class="text-sm font-bold uppercase tracking-wide text-red-600">Application Error</p>
        <h1 class="mt-3 text-3xl font-black tracking-normal">Something went wrong.</h1>
        <p class="mt-4 text-stone-600">The request could not be completed. Please try again in a moment.</p>
        @if (Model.ShowRequestId)
        {
            <p class="mt-6 rounded-md bg-stone-50 px-4 py-3 text-sm text-stone-500">
                Request ID: <code>@Model.RequestId</code>
            </p>
        }
        <a class="mt-8 inline-flex rounded-full bg-ink px-6 py-3 text-sm font-black text-white" asp-controller="Home" asp-action="Index">Back to Home</a>
    </div>
</section>
