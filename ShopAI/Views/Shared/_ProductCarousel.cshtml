@model ProductCarouselSectionViewModel

<section id="@Model.Id" class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8" data-aos="fade-up">
    <div class="mb-6 flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
            <p class="text-sm font-black text-brand-600">@Model.Eyebrow</p>
            <h2 class="mt-2 text-3xl font-black tracking-normal text-slate-950">@Model.Title</h2>
        </div>
        <div class="flex items-center gap-2">
            <button type="button" class="carousel-prev grid h-11 w-11 place-items-center rounded-2xl border border-slate-200 bg-white text-slate-700 transition hover:border-brand-500 hover:text-brand-600" aria-label="السابق">
                <i data-lucide="chevron-right" class="h-5 w-5"></i>
            </button>
            <button type="button" class="carousel-next grid h-11 w-11 place-items-center rounded-2xl border border-slate-200 bg-white text-slate-700 transition hover:border-brand-500 hover:text-brand-600" aria-label="التالي">
                <i data-lucide="chevron-left" class="h-5 w-5"></i>
            </button>
            <a class="mr-2 rounded-2xl bg-slate-950 px-5 py-3 text-sm font-black text-white transition hover:bg-brand-700" href="@Model.ViewAllUrl">عرض الكل</a>
        </div>
    </div>

    @if (Model.Products.Count == 0)
    {
        <div class="rounded-3xl border border-dashed border-slate-300 bg-white p-10 text-center text-slate-500">
            لا توجد منتجات في هذا القسم حالياً.
        </div>
    }
    else
    {
        <div class="swiper smartstore-product-swiper" data-swiper="products">
            <div class="swiper-wrapper pb-8">
                @foreach (var product in Model.Products)
                {
                    <div class="swiper-slide h-auto">
                        @await Html.PartialAsync("_ProductCard", product)
                    </div>
                }
            </div>
        </div>
    }
</section>
