@{
    var query = Context.Request.Query["q"].ToString();
}

<form action="/search" method="get" class="smart-search-shell group relative w-full">
    <label class="sr-only" for="site-search">البحث عن المنتجات</label>
    <i data-lucide="search" class="pointer-events-none absolute right-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400 transition group-focus-within:text-brand-600"></i>
    <input id="site-search" name="q" value="@query" autocomplete="off" class="h-12 w-full rounded-2xl border border-white/70 bg-white/85 pr-12 pl-4 text-sm font-bold text-slate-800 shadow-sm outline-none backdrop-blur transition placeholder:text-slate-400 focus:border-cyan-300 focus:bg-white focus:ring-4 focus:ring-cyan-400/15" placeholder="ابحث عن هاتف، لابتوب، سماعة..." />
    <button type="submit" class="absolute left-2 top-1/2 hidden -translate-y-1/2 rounded-xl bg-slate-950 px-4 py-2 text-xs font-black text-white transition hover:bg-brand-700 sm:block">
        بحث
    </button>
</form>
