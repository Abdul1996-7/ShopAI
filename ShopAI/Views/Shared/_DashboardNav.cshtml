@{
    var active = ViewData["ActiveNav"]?.ToString();
    string LinkClass(string key) => active == key
        ? "bg-slate-950 text-white shadow-lg shadow-slate-950/15"
        : "text-slate-600 hover:bg-slate-100 hover:text-slate-950";
}

<aside class="rounded-[2rem] border border-slate-200 bg-white p-3 shadow-soft lg:sticky lg:top-36 lg:h-fit" data-aos="fade-left">
    <div class="mb-4 rounded-3xl bg-gradient-to-br from-slate-950 to-brand-900 p-4 text-white">
        <p class="text-xs font-black text-cyan-200">SmartStore SaaS</p>
        <p class="mt-2 text-lg font-black">لوحة البائع</p>
    </div>
    <nav class="grid gap-1">
        <a class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-black transition @LinkClass("Dashboard")" asp-controller="Dashboard" asp-action="Index">
            <i data-lucide="layout-dashboard" class="h-5 w-5"></i>
            لوحة التحكم
        </a>
        <a class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-black transition @LinkClass("Products")" asp-controller="Dashboard" asp-action="Products">
            <i data-lucide="boxes" class="h-5 w-5"></i>
            منتجاتي
        </a>
        <a class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-black transition @LinkClass("Create")" asp-controller="Dashboard" asp-action="Create">
            <i data-lucide="circle-plus" class="h-5 w-5"></i>
            إضافة منتج
        </a>
        <a class="flex items-center gap-3 rounded-2xl px-4 py-3 text-sm font-black text-slate-400 transition hover:bg-slate-100 hover:text-slate-700" href="#">
            <i data-lucide="settings" class="h-5 w-5"></i>
            الإعدادات
        </a>
    </nav>
</aside>
