@model string

<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8" aria-busy="true">
    <div class="mb-6 flex items-end justify-between">
        <div>
            <div class="h-4 w-28 animate-pulse rounded-full bg-slate-200"></div>
            <div class="mt-3 h-9 w-56 animate-pulse rounded-2xl bg-slate-200"></div>
        </div>
        <div class="hidden h-11 w-28 animate-pulse rounded-2xl bg-slate-200 sm:block"></div>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        @for (var index = 0; index < 4; index++)
        {
            <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
                <div class="aspect-[4/3] animate-pulse bg-slate-200"></div>
                <div class="space-y-3 p-5">
                    <div class="h-4 w-3/4 animate-pulse rounded-full bg-slate-200"></div>
                    <div class="h-4 w-1/2 animate-pulse rounded-full bg-slate-200"></div>
                    <div class="h-10 w-full animate-pulse rounded-2xl bg-slate-200"></div>
                </div>
            </div>
        }
    </div>
</section>
