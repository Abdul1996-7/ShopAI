@model SearchResultsViewModel
@{
    ViewData["Title"] = "البحث";
}

<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-[2rem] bg-slate-950 p-6 text-white shadow-soft sm:p-8" data-aos="fade-up">
        <div class="absolute inset-0 opacity-50" style="background-image: radial-gradient(circle at 20% 20%, rgba(56,189,248,.45), transparent 30%), radial-gradient(circle at 80% 20%, rgba(37,99,235,.45), transparent 28%);"></div>
        <div class="relative">
            <p class="text-sm font-black text-cyan-200">بحث SmartStore</p>
            <h1 class="mt-3 text-3xl font-black tracking-normal sm:text-5xl">اعثر على جهازك القادم بسرعة</h1>
            <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">اكتب اسم المنتج أو اختر قسماً، وستتحدث النتائج بدون تحميل الصفحة بالكامل.</p>

            <form id="smart-search-form"
                  class="mt-8 grid gap-3 rounded-3xl border border-white/10 bg-white/10 p-3 backdrop-blur-xl md:grid-cols-[1fr_280px_auto]"
                  hx-get="/search/results"
                  hx-target="#search-results"
                  hx-swap="innerHTML"
                  hx-trigger="submit, keyup changed delay:350ms from:#search-query, change from:#category-select">
                <label class="sr-only" for="search-query">كلمة البحث</label>
                <div class="relative">
                    <i data-lucide="search" class="pointer-events-none absolute right-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400"></i>
                    <input id="search-query" name="q" value="@Model.Query" autocomplete="off" class="h-14 w-full rounded-2xl border border-white/20 bg-white pr-12 pl-4 text-sm font-bold text-slate-950 outline-none focus:border-cyan-300 focus:ring-4 focus:ring-cyan-300/20" placeholder="ابحث عن لابتوب، هاتف، سماعة..." />
                </div>
                <select id="category-select" name="category" data-tom-select class="h-14 rounded-2xl bg-white text-slate-950">
                    <option value="">كل الأقسام</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.CategoryId == category.Id)
                        {
                            <option value="@category.Id" selected>@category.Name</option>
                        }
                        else
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    }
                </select>
                <button type="submit" class="inline-flex h-14 items-center justify-center gap-2 rounded-2xl bg-cyan-400 px-6 text-sm font-black text-slate-950 transition hover:bg-cyan-300">
                    <i data-lucide="sparkles" class="h-4 w-4"></i>
                    تحديث
                </button>
            </form>
        </div>
    </div>

    <div id="search-results" class="mt-10">
        @await Html.PartialAsync("_SearchResults", Model)
    </div>
</section>
