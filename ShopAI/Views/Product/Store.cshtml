@model StorePageViewModel
@{
    ViewData["Title"] = Model.StoreName;
}

<section class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-[2rem] bg-slate-950 p-6 text-white shadow-soft sm:p-8" data-aos="fade-up">
        <div class="absolute inset-0 opacity-50" style="background-image: radial-gradient(circle at 20% 20%, rgba(56,189,248,.45), transparent 30%), radial-gradient(circle at 80% 70%, rgba(37,99,235,.45), transparent 28%);"></div>
        <div class="relative grid gap-6 md:grid-cols-[1fr_auto] md:items-end">
            <div class="flex flex-col gap-5 sm:flex-row sm:items-center">
                <img src="@(Model.LogoUrl ?? "/images/logo-placeholder.svg")" alt="شعار @Model.StoreName" class="h-24 w-24 rounded-3xl border border-white/20 bg-white object-cover p-2 shadow-lg" />
                <div>
                    <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-black text-cyan-100">
                        <i data-lucide="badge-check" class="h-4 w-4"></i>
                        ملف المتجر
                    </p>
                    <h1 class="mt-4 text-4xl font-black tracking-normal">@Model.StoreName</h1>
                    <p class="mt-3 max-w-2xl text-sm leading-7 text-slate-300">@Model.Description</p>
                </div>
            </div>
            <div class="rounded-3xl border border-white/15 bg-white/10 p-5 text-sm text-slate-200 backdrop-blur">
                <p class="font-black text-white">منتجات المتجر</p>
                <p class="mt-2 text-3xl font-black text-cyan-200">@Model.Products.Count</p>
                <p class="mt-1">صفحة @Model.CurrentPage من @Model.TotalPages</p>
            </div>
        </div>
    </div>

    @if (Model.Products.Count == 0)
    {
        <div class="mt-8 rounded-3xl border border-slate-200 bg-white p-12 text-center shadow-soft" data-aos="fade-up">
            <div class="mx-auto grid h-16 w-16 place-items-center rounded-3xl bg-slate-100 text-slate-500">
                <i data-lucide="package-open" class="h-7 w-7"></i>
            </div>
            <h2 class="mt-5 text-2xl font-black text-slate-950">لا توجد منتجات منشورة حالياً</h2>
            <p class="mt-3 text-slate-500">سيظهر مخزون المتجر هنا عند نشر المنتجات.</p>
        </div>
    }
    else
    {
        <div class="mt-10 grid gap-5 sm:grid-cols-2 xl:grid-cols-4" data-aos="fade-up">
            @foreach (var product in Model.Products)
            {
                @await Html.PartialAsync("_ProductCard", product)
            }
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <div class="mt-10 flex items-center justify-center gap-2">
            @for (var page = 1; page <= Model.TotalPages; page++)
            {
                <a class="grid h-10 w-10 place-items-center rounded-full text-sm font-black @(page == Model.CurrentPage ? "bg-slate-950 text-white" : "border border-slate-200 bg-white text-slate-700 hover:border-brand-500")" href="/store/@Model.StoreSlug?page=@(page)">@(page)</a>
            }
        </div>
    }
</section>
