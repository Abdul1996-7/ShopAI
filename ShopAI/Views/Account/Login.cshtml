@model LoginViewModel
@{
    ViewData["Title"] = "تسجيل الدخول";
}

<section class="mx-auto grid min-h-[calc(100vh-10rem)] max-w-7xl items-center gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_420px] lg:px-8">
    <div class="max-w-2xl">
        <p class="text-sm font-black text-brand-600">دخول البائعين</p>
        <h1 class="mt-3 text-4xl font-black leading-tight tracking-normal text-slate-950 sm:text-5xl">أدر متجرك الإلكتروني بثقة ووضوح.</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">سجّل الدخول لإضافة المنتجات، متابعة المخزون، وتحسين تجربة متجرك العامة.</p>
    </div>

    <form asp-action="Login" method="post" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <input asp-for="ReturnUrl" type="hidden" />
        <h2 class="text-2xl font-black text-slate-950">مرحباً بعودتك</h2>
        <div asp-validation-summary="ModelOnly" class="mt-4 text-sm"></div>
        <div class="mt-6 grid gap-4">
            <div>
                <label asp-for="Email" class="mb-2 block text-sm font-black">البريد الإلكتروني</label>
                <input asp-for="Email" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" placeholder="seller@example.com" />
                <span asp-validation-for="Email" class="mt-1 block text-sm"></span>
            </div>
            <div>
                <label asp-for="Password" class="mb-2 block text-sm font-black">كلمة المرور</label>
                <input asp-for="Password" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="Password" class="mt-1 block text-sm"></span>
            </div>
            <label class="flex items-center gap-3 text-sm font-bold text-slate-600">
                <input asp-for="RememberMe" class="h-5 w-5 rounded border-slate-300 text-brand-600 focus:ring-brand-500" />
                تذكرني
            </label>
        </div>
        <button class="mt-6 w-full rounded-2xl bg-slate-950 px-6 py-4 text-sm font-black text-white transition hover:bg-brand-900" type="submit">تسجيل الدخول</button>
        <p class="mt-5 text-center text-sm text-slate-500">ليس لديك متجر؟ <a class="font-black text-brand-600 hover:text-brand-900" asp-action="Register">أنشئ متجراً الآن</a></p>
    </form>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
