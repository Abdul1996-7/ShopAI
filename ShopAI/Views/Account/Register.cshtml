@model RegisterViewModel
@{
    ViewData["Title"] = "إنشاء متجر";
}

<section class="mx-auto grid min-h-[calc(100vh-10rem)] max-w-7xl items-center gap-10 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_460px] lg:px-8">
    <div class="max-w-2xl">
        <p class="text-sm font-black text-brand-600">انضم كبائع</p>
        <h1 class="mt-3 text-4xl font-black leading-tight tracking-normal text-slate-950 sm:text-5xl">أنشئ واجهة متجرك الإلكترونية خلال دقائق.</h1>
        <p class="mt-5 text-lg leading-8 text-slate-600">سجل حسابك، أنشئ متجراً عاماً، وابدأ بإضافة الهواتف واللابتوبات والإكسسوارات بتجربة عربية احترافية.</p>
        <div class="mt-8 grid gap-3 text-sm text-slate-600 sm:grid-cols-3">
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-soft">
                <p class="font-black text-slate-950">متجر</p>
                <p class="mt-1">رابط عام فريد</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-soft">
                <p class="font-black text-slate-950">كتالوج</p>
                <p class="mt-1">منتجات ومواصفات</p>
            </div>
            <div class="rounded-3xl border border-slate-200 bg-white p-4 shadow-soft">
                <p class="font-black text-slate-950">جاهزية</p>
                <p class="mt-1">لمراحل الذكاء القادمة</p>
            </div>
        </div>
    </div>

    <form asp-action="Register" method="post" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-soft">
        <h2 class="text-2xl font-black text-slate-950">ابدأ البيع</h2>
        <div asp-validation-summary="ModelOnly" class="mt-4 text-sm"></div>
        <div class="mt-6 grid gap-4">
            <div>
                <label asp-for="FullName" class="mb-2 block text-sm font-black">الاسم الكامل</label>
                <input asp-for="FullName" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="FullName" class="mt-1 block text-sm"></span>
            </div>
            <div>
                <label asp-for="StoreName" class="mb-2 block text-sm font-black">اسم المتجر</label>
                <input asp-for="StoreName" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="StoreName" class="mt-1 block text-sm"></span>
            </div>
            <div>
                <label asp-for="Email" class="mb-2 block text-sm font-black">البريد الإلكتروني</label>
                <input asp-for="Email" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="Email" class="mt-1 block text-sm"></span>
            </div>
            <div>
                <label asp-for="Password" class="mb-2 block text-sm font-black">كلمة المرور</label>
                <input asp-for="Password" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="Password" class="mt-1 block text-sm"></span>
            </div>
            <div>
                <label asp-for="ConfirmPassword" class="mb-2 block text-sm font-black">تأكيد كلمة المرور</label>
                <input asp-for="ConfirmPassword" class="h-12 w-full rounded-2xl border border-slate-200 px-4 outline-none focus:border-brand-500 focus:ring-4 focus:ring-brand-500/10" />
                <span asp-validation-for="ConfirmPassword" class="mt-1 block text-sm"></span>
            </div>
        </div>
        <button class="mt-6 w-full rounded-2xl bg-slate-950 px-6 py-4 text-sm font-black text-white transition hover:bg-brand-900" type="submit">إنشاء المتجر</button>
        <p class="mt-5 text-center text-sm text-slate-500">لديك حساب؟ <a class="font-black text-brand-600 hover:text-brand-900" asp-action="Login">تسجيل الدخول</a></p>
    </form>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
